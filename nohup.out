   \u003cuses-permission android:name=\"android.permission.READ_EXTERNAL_STORAGE\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.READ_MEDIA_IMAGES\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.READ_MEDIA_VIDEO\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.CAMERA\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.POST_NOTIFICATIONS\"/\u003e\n\n              \u003capplication\n                  android:label=\"PhotoSync\"\n                  android:name=\"${applicationName}\"\n                  android:icon=\"@mipmap/ic_launcher\"\n                  android:requestLegacyExternalStorage=\"true\"\u003e\n                  \u003cactivity\n                      android:name=\".MainActivity\"\n                      android:exported=\"true\"\n                      android:launchMode=\"singleTop\"\n                      android:taskAffinity=\"\"\n                      android:theme=\"@style/LaunchTheme\"\n                      android:configChanges=\"orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode\"\n                      android:hardwareAccelerated=\"true\"\n                      android:windowSoftInputMode=\"adjustResize\"\u003e\n                      \u003cmeta-data\n                          android:name=\"io.flutter.embedding.android.NormalTheme\"\n                          android:resource=\"@style/NormalTheme\"/\u003e\n                      \u003cintent-filter\u003e\n                          \u003caction android:name=\"android.intent.action.MAIN\"/\u003e\n                          \u003ccategory android:name=\"android.intent.category.LAUNCHER\"/\u003e\n                      \u003c/intent-filter\u003e\n                  \u003c/activity\u003e\n                  \u003cmeta-data\n                      android:name=\"flutterEmbedding\"\n                      android:value=\"2\"/\u003e\n              \u003c/application\u003e\n\n              \u003cqueries\u003e\n                  \u003cintent\u003e\n                      \u003caction android:name=\"android.intent.action.PROCESS_TEXT\"/\u003e\n                      \u003cdata android:mimeType=\"text/plain\"/\u003e\n                  \u003c/intent\u003e\n              \u003c/queries\u003e\n          \u003c/manifest\u003e\n          MANIFEST_EOF\n\n      - name: Configure Kotlin and Gradle\n        run: |\n          cd app_mobile/android\n          # 升级 Kotlin 版本到 1.9.22 以兼容 shared_preferences_android 2.4.7\n          sed -i 's/org.jetbrains.kotlin.android\" version \"[^\"]*\"/org.jetbrains.kotlin.android\" version \"1.9.22\"/' settings.gradle\n          sed -i 's/ext.kotlin_version = .*/ext.kotlin_version = \"1.9.22\"/' build.gradle || true\n          cd app\n          sed -i 's/minSdk = .*/minSdk = 21/' build.gradle\n          sed -i 's/targetSdk = .*/targetSdk = 34/' build.gradle\n          sed -i 's/compileSdk = .*/compileSdk = 34/' build.gradle\n          sed -i 's/applicationId = .*/applicationId = \"com.photosync.app\"/' build.gradle || true\n          echo \"=== settings.gradle kotlin version ===\"\n          grep -i kotlin ../settings.gradle || true\n          echo \"=== app/build.gradle sdk versions ===\"\n          grep -E '(minSdk|targetSdk|compileSdk)' build.gradle || true\n\n      - name: Build Debug APK\n        run: |\n          cd app_mobile\n          flutter build apk --debug\n\n      - name: Build Release APK\n        run: |\n          cd app_mobile\n          flutter build apk --release\n\n      - name: Upload Debug APK\n        uses: actions/upload-artifact@v4\n        with:\n          name: app-debug\n          path: app_mobile/build/app/outputs/flutter-apk/app-debug.apk\n          retention-days: 30\n\n      - name: Upload Release APK\n        uses: actions/upload-artifact@v4\n        with:\n          name: app-release\n          path: app_mobile/build/app/outputs/flutter-apk/app-release.apk\n          retention-days: 30\n\n      - name: APK Info\n        run: |\n          echo \"=== Debug APK ===\"\n          ls -lh app_mobile/build/app/outputs/flutter-apk/app-debug.apk\n          echo \"\"\n          echo \"=== Release APK ===\"\n          ls -lh app_mobile/build/app/outputs/flutter-apk/app-release.apk\n'''\nwith open('/Users/bytedance/go/src/github.com/liulanghai/photo-sync/.github/workflows/build-apk.yml', 'w') as f:\n    f.write(content)\nprint('build-apk.yml written')\nPYEOF"},"name":"bash"},"id":77}
