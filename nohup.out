Debug 2026-04-14 19:55:12,309 v1(7) mcp_stdio.go:232 10.74.28.96 lark.infra.delivery_platform_test - default - 0 _env=prod _env_type=- [MCPServer] send: {"jsonrpc":"2.0","method":"tools/call","params":{"arguments":{"command":"python3 -c \"\ncontent = '''import 'photo_info.dart';\n\n/// 同步任务模型\nenum SyncStatus {\n  pending,   // 待同步\n  syncing,   // 同步中\n  success,   // 成功\n  failed,    // 失败\n  skipped,   // 跳过（去重/已存在）\n  paused,    // 暂停\n}\n\nclass SyncTask {\n  final String id;\n  final List\u003cPhotoInfo\u003e files;\n  SyncStatus status;\n  int currentIndex;\n  int totalFiles;\n  int transferredBytes;\n  int totalBytes;\n  String? errorMessage;\n  DateTime startTime;\n  DateTime? endTime;\n  final List\u003cSyncFileResult\u003e results;\n\n  SyncTask({\n    required this.id,\n    required this.files,\n    this.status = SyncStatus.pending,\n    this.currentIndex = 0,\n    this.transferredBytes = 0,\n    this.errorMessage,\n    DateTime? startTime,\n    this.endTime,\n    List\u003cSyncFileResult\u003e? results,\n  })  : totalFiles = files.length,\n        totalBytes = files.fold\u003cint\u003e(0, (sum, f) =\u003e sum + f.fileSize),\n        startTime = startTime ?? DateTime.now(),\n        results = results ?? [];\n\n  /// 当前进度百分比 0.0 - 1.0\n  double get progress =\u003e\n      totalFiles == 0 ? 0.0 : currentIndex / totalFiles;\n\n  /// 已传输大小（可读格式）\n  String get transferredSizeFormatted =\u003e _formatBytes(transferredBytes);\n\n  /// 总大小（可读格式）\n  String get totalSizeFormatted =\u003e _formatBytes(totalBytes);\n\n  /// 成功数量\n  int get successCount =\u003e\n      results.where((r) =\u003e r.status == SyncStatus.success).length;\n\n  /// 失败数量\n  int get failedCount =\u003e\n      results.where((r) =\u003e r.status == SyncStatus.failed).length;\n\n  /// 跳过数量\n  int get skippedCount =\u003e\n      results.where((r) =\u003e r.status == SyncStatus.skipped).length;\n\n  static String _formatBytes(int bytes) {\n    if (bytes \u003c 1024) return '\\\\x24bytes B';\n    if (bytes \u003c 1024 * 1024) return '\\\\x24{(bytes / 1024).toStringAsFixed(1)} KB';\n    if (bytes \u003c 1024 * 1024 * 1024) {\n      return '\\\\x24{(bytes / (1024 * 1024)).toStringAsFixed(1)} MB';\n    }\n    return '\\\\x24{(bytes / (1024 * 1024 * 1024)).toStringAsFixed(2)} GB';\n  }\n}\n\n/// 单个文件同步结果\nclass SyncFileResult {\n  final PhotoInfo file;\n  final SyncStatus status;\n  final String? remotePath;\n  final String? errorMessage;\n\n  SyncFileResult({\n    required this.file,\n    required this.status,\n    this.remotePath,\n    this.errorMessage,\n  });\n}\n'''\nwith open('/Users/bytedance/go/src/github.com/liulanghai/photo-sync/packages/photo_sync_core/lib/src/models/sync_task.dart', 'w') as f:\n    f.write(content)\nprint('sync_task.dart written')\n\""},"name":"bash"},"id":48}
