Debug 2026-04-14 21:00:31,675 v1(7) mcp_stdio.go:232 10.74.28.96 lark.infra.delivery_platform_test - default - 0 _env=prod _env_type=- [MCPServer] send: {"jsonrpc":"2.0","method":"tools/call","params":{"arguments":{"command":"python3 \u003c\u003c 'PYEOF'\ncontent = r'''name: Release APK\n\non:\n  push:\n    tags:\n      - 'v*'\n\njobs:\n  build-and-release:\n    name: Build \u0026 Release APK\n    runs-on: ubuntu-latest\n    timeout-minutes: 30\n    permissions:\n      contents: write\n\n    steps:\n      - name: Checkout code\n        uses: actions/checkout@v4\n\n      - name: Setup Java\n        uses: actions/setup-java@v4\n        with:\n          distribution: 'zulu'\n          java-version: '17'\n\n      - name: Setup Flutter\n        uses: subosito/flutter-action@v2\n        with:\n          flutter-version: '3.24.0'\n          channel: 'stable'\n          cache: true\n\n      - name: Install dependencies\n        run: |\n          cd packages/photo_sync_core \u0026\u0026 dart pub get\n          cd ../../app_mobile \u0026\u0026 flutter pub get\n\n      - name: Create Android platform files\n        run: |\n          cd app_mobile\n          if [ ! -d \"android\" ]; then\n            flutter create --platforms=android .\n          fi\n\n      - name: Configure Android manifest\n        run: |\n          cat \u003e app_mobile/android/app/src/main/AndroidManifest.xml \u003c\u003c 'MANIFEST_EOF'\n          \u003cmanifest xmlns:android=\"http://schemas.android.com/apk/res/android\"\u003e\n              \u003cuses-permission android:name=\"android.permission.INTERNET\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.ACCESS_WIFI_STATE\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.ACCESS_NETWORK_STATE\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.CHANGE_WIFI_MULTICAST_STATE\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.READ_EXTERNAL_STORAGE\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.READ_MEDIA_IMAGES\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.READ_MEDIA_VIDEO\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.CAMERA\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.POST_NOTIFICATIONS\"/\u003e\n              \u003capplication\n                  android:label=\"PhotoSync\"\n                  android:name=\"${applicationName}\"\n                  android:icon=\"@mipmap/ic_launcher\"\n                  android:requestLegacyExternalStorage=\"true\"\u003e\n                  \u003cactivity\n                      android:name=\".MainActivity\"\n                      android:exported=\"true\"\n                      android:launchMode=\"singleTop\"\n                      android:taskAffinity=\"\"\n                      android:theme=\"@style/LaunchTheme\"\n                      android:configChanges=\"orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode\"\n                      android:hardwareAccelerated=\"true\"\n                      android:windowSoftInputMode=\"adjustResize\"\u003e\n                      \u003cmeta-data\n                          android:name=\"io.flutter.embedding.android.NormalTheme\"\n                          android:resource=\"@style/NormalTheme\"/\u003e\n                      \u003cintent-filter\u003e\n                          \u003caction android:name=\"android.intent.action.MAIN\"/\u003e\n                          \u003ccategory android:name=\"android.intent.category.LAUNCHER\"/\u003e\n                      \u003c/intent-filter\u003e\n                  \u003c/activity\u003e\n                  \u003cmeta-data\n                      android:name=\"flutterEmbedding\"\n                      android:value=\"2\"/\u003e\n              \u003c/application\u003e\n              \u003cqueries\u003e\n                  \u003cintent\u003e\n                      \u003caction android:name=\"android.intent.action.PROCESS_TEXT\"/\u003e\n                      \u003cdata android:mimeType=\"text/plain\"/\u003e\n                  \u003c/intent\u003e\n              \u003c/queries\u003e\n          \u003c/manifest\u003e\n          MANIFEST_EOF\n\n      - name: Configure Kotlin and Gradle\n        run: |\n          cd app_mobile/android\n\n          cat \u003e settings.gradle \u003c\u003c 'SETTINGS_EOF'\n          pluginManagement {\n              def flutterSdkPath = {\n                  def properties = new Properties()\n                  file(\"local.properties\").withInputStream { properties.load(it) }\n                  def flutterSdkPath = properties.getProperty(\"flutter.sdk\")\n                  assert flutterSdkPath != null, \"flutter.sdk not set in local.properties\"\n                  return flutterSdkPath\n              }()\n\n              includeBuild(\"${flutterSdkPath}/packages/flutter_tools/gradle\")\n\n              repositories {\n                  google()\n                  mavenCentral()\n                  gradlePluginPortal()\n              }\n          }\n\n          plugins {\n              id \"dev.flutter.flutter-plugin-loader\" version \"1.0.0\"\n              id \"com.android.application\" version \"8.5.0\" apply false\n              id \"org.jetbrains.kotlin.android\" version \"2.0.0\" apply false\n          }\n\n          include \":app\"\n          SETTINGS_EOF\n\n          cd app\n          sed -i 's/minSdk\\s*=\\s*[0-9]*/minSdk = 21/' build.gradle\n          sed -i 's/targetSdk\\s*=\\s*[0-9]*/targetSdk = 34/' build.gradle\n          sed -i 's/compileSdk\\s*=\\s*[0-9]*/compileSdk = 34/' build.gradle\n\n      - name: Build Release APK\n        run: |\n          cd app_mobile\n          flutter build apk --release\n\n      - name: Rename APK with version\n        run: |\n          VERSION=${GITHUB_REF#refs/tags/}\n          cp app_mobile/build/app/outputs/flutter-apk/app-release.apk \\\n             app_mobile/build/app/outputs/flutter-apk/PhotoSync-${VERSION}.apk\n\n      - name: Create GitHub Release\n        uses: softprops/action-gh-release@v2\n        with:\n          files: |\n            app_mobile/build/app/outputs/flutter-apk/PhotoSync-*.apk\n            app_mobile/build/app/outputs/flutter-apk/app-release.apk\n          generate_release_notes: true\n          draft: false\n          prerelease: false\n'''\n\nwith open('/Users/bytedance/go/src/github.com/liulanghai/photo-sync/.github/workflows/release.yml', 'w') as f:\n    f.write(content)\nprint('release.yml done')\nPYEOF"},"name":"bash"},"id":91}
