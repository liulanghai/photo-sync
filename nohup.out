Debug 2026-04-14 21:11:56,096 v1(7) mcp_stdio.go:232 10.74.28.96 lark.infra.delivery_platform_test - default - 0 _env=prod _env_type=- [MCPServer] send: {"jsonrpc":"2.0","method":"tools/call","params":{"arguments":{"command":"python3 \u003c\u003c 'PYEOF'\nimport os\n\n# 新的 build-all.yml\nbuild_all = r'''name: Build All Platforms\n\non:\n  push:\n    branches: [ main, master ]\n  pull_request:\n    branches: [ main, master ]\n  workflow_dispatch:\n\njobs:\n  build-android:\n    name: Android APK\n    runs-on: ubuntu-latest\n    timeout-minutes: 30\n    steps:\n      - uses: actions/checkout@v4\n      - uses: actions/setup-java@v4\n        with:\n          distribution: 'zulu'\n          java-version: '17'\n      - uses: subosito/flutter-action@v2\n        with:\n          flutter-version: '3.24.0'\n          channel: 'stable'\n          cache: true\n      - name: Install dependencies\n        run: |\n          cd packages/photo_sync_core \u0026\u0026 dart pub get\n          cd ../../app_mobile \u0026\u0026 flutter pub get\n      - name: Create Android platform files\n        run: |\n          cd app_mobile\n          if [ ! -d \"android\" ]; then flutter create --platforms=android . ; fi\n      - name: Patch Android config\n        run: |\n          cd app_mobile/android\n\n          # 1) 覆写 settings.gradle: Kotlin 2.0.0 + AGP 8.5.0\n          cat \u003e settings.gradle \u003c\u003c 'SETTINGS_EOF'\n          pluginManagement {\n              def flutterSdkPath = {\n                  def properties = new Properties()\n                  file(\"local.properties\").withInputStream { properties.load(it) }\n                  def flutterSdkPath = properties.getProperty(\"flutter.sdk\")\n                  assert flutterSdkPath != null, \"flutter.sdk not set in local.properties\"\n                  return flutterSdkPath\n              }()\n              includeBuild(\"${flutterSdkPath}/packages/flutter_tools/gradle\")\n              repositories {\n                  google()\n                  mavenCentral()\n                  gradlePluginPortal()\n              }\n          }\n          plugins {\n              id \"dev.flutter.flutter-plugin-loader\" version \"1.0.0\"\n              id \"com.android.application\" version \"8.5.0\" apply false\n              id \"org.jetbrains.kotlin.android\" version \"2.0.0\" apply false\n          }\n          include \":app\"\n          SETTINGS_EOF\n\n          # 2) 升级 Gradle wrapper -\u003e 8.7\n          sed -i \"s|distributionUrl=.*|distributionUrl=https\\\\://services.gradle.org/distributions/gradle-8.7-all.zip|\" gradle/wrapper/gradle-wrapper.properties\n\n          # 3) 覆写 app/build.gradle\n          cat \u003e app/build.gradle \u003c\u003c 'GRADLE_EOF'\n          plugins {\n              id \"com.android.application\"\n              id \"kotlin-android\"\n              id \"dev.flutter.flutter-gradle-plugin\"\n          }\n\n          android {\n              namespace = \"com.photosync.app\"\n              compileSdk = 34\n              ndkVersion = flutter.ndkVersion\n\n              compileOptions {\n                  sourceCompatibility = JavaVersion.VERSION_1_8\n                  targetCompatibility = JavaVersion.VERSION_1_8\n              }\n\n              kotlinOptions {\n                  jvmTarget = JavaVersion.VERSION_1_8\n              }\n\n              defaultConfig {\n                  applicationId = \"com.photosync.app\"\n                  minSdk = 21\n                  targetSdk = 34\n                  versionCode = flutter.versionCode\n                  versionName = flutter.versionName\n              }\n\n              buildTypes {\n                  release {\n                      signingConfig = signingConfigs.debug\n                  }\n              }\n          }\n\n          flutter {\n              source = \"../..\"\n          }\n          GRADLE_EOF\n\n          # 4) 覆写 AndroidManifest.xml\n          cat \u003e app/src/main/AndroidManifest.xml \u003c\u003c 'MANIFEST_EOF'\n          \u003cmanifest xmlns:android=\"http://schemas.android.com/apk/res/android\"\u003e\n              \u003cuses-permission android:name=\"android.permission.INTERNET\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.ACCESS_WIFI_STATE\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.ACCESS_NETWORK_STATE\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.CHANGE_WIFI_MULTICAST_STATE\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.READ_EXTERNAL_STORAGE\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.READ_MEDIA_IMAGES\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.READ_MEDIA_VIDEO\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.CAMERA\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.POST_NOTIFICATIONS\"/\u003e\n              \u003capplication android:label=\"PhotoSync\" android:name=\"${applicationName}\" android:icon=\"@mipmap/ic_launcher\" android:requestLegacyExternalStorage=\"true\"\u003e\n                  \u003cactivity android:name=\".MainActivity\" android:exported=\"true\" android:launchMode=\"singleTop\" android:taskAffinity=\"\" android:theme=\"@style/LaunchTheme\" android:configChanges=\"orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode\" android:hardwareAccelerated=\"true\" android:windowSoftInputMode=\"adjustResize\"\u003e\n                      \u003cmeta-data android:name=\"io.flutter.embedding.android.NormalTheme\" android:resource=\"@style/NormalTheme\"/\u003e\n                      \u003cintent-filter\u003e\u003caction android:name=\"android.intent.action.MAIN\"/\u003e\u003ccategory android:name=\"android.intent.category.LAUNCHER\"/\u003e\u003c/intent-filter\u003e\n                  \u003c/activity\u003e\n                  \u003cmeta-data android:name=\"flutterEmbedding\" android:value=\"2\"/\u003e\n              \u003c/application\u003e\n              \u003cqueries\u003e\u003cintent\u003e\u003caction android:name=\"android.intent.action.PROCESS_TEXT\"/\u003e\u003cdata android:mimeType=\"text/plain\"/\u003e\u003c/intent\u003e\u003c/queries\u003e\n          \u003c/manifest\u003e\n          MANIFEST_EOF\n\n          echo \"=== Patched settings.gradle ===\"\n          head -5 settings.gradle\n          echo \"=== Patched app/build.gradle ===\"\n          head -15 app/build.gradle\n          echo \"=== Gradle wrapper ===\"\n          grep distributionUrl gradle/wrapper/gradle-wrapper.properties\n      - name: Build Release APK\n        run: cd app_mobile \u0026\u0026 flutter build apk --release\n      - uses: actions/upload-artifact@v4\n        with:\n          name: PhotoSync-Android\n          path: app_mobile/build/app/outputs/flutter-apk/app-release.apk\n          retention-days: 30\n\n  build-windows:\n    name: Windows Desktop\n    runs-on: windows-latest\n    timeout-minutes: 30\n    steps:\n      - uses: actions/checkout@v4\n      - uses: subosito/flutter-action@v2\n        with:\n          flutter-version: '3.24.0'\n          channel: 'stable'\n          cache: true\n      - name: Build\n        run: |\n          flutter config --enable-windows-desktop\n          cd packages/photo_sync_core; dart pub get\n          cd ../../app_desktop; flutter pub get\n          if (!(Test-Path \"windows\")) { flutter create --platforms=windows . }\n          flutter build windows --release\n        shell: pwsh\n      - name: Package\n        run: |\n          cd app_desktop/build/windows/x64/runner/Release\n          Compress-Archive -Path * -DestinationPath PhotoSync-Windows.zip\n        shell: pwsh\n      - uses: actions/upload-artifact@v4\n        with:\n          name: PhotoSync-Windows\n          path: app_desktop/build/windows/x64/runner/Release/PhotoSync-Windows.zip\n          retention-days: 30\n\n  build-macos:\n    name: macOS Desktop\n    runs-on: macos-latest\n    timeout-minutes: 30\n    steps:\n      - uses: actions/checkout@v4\n      - uses: subosito/flutter-action@v2\n        with:\n          flutter-version: '3.24.0'\n          channel: 'stable'\n          cache: true\n      - name: Build\n        run: |\n          flutter config --enable-macos-desktop\n          cd packages/photo_sync_core \u0026\u0026 dart pub get\n          cd ../../app_desktop \u0026\u0026 flutter pub get\n          if [ ! -d \"macos\" ]; then flutter create --platforms=macos . ; fi\n          cd macos/Runner\n          for f in DebugProfile.entitlements Release.entitlements; do\n            cat \u003e $f \u003c\u003c 'ENTITLEMENTS_EOF'\n          \u003c?xml version=\"1.0\" encoding=\"UTF-8\"?\u003e\n          \u003c!DOCTYPE plist PUBLIC \"-//Apple//DTD PLIST 1.0//EN\" \"http://www.apple.com/DTDs/PropertyList-1.0.dtd\"\u003e\n          \u003cplist version=\"1.0\"\u003e\n          \u003cdict\u003e\n              \u003ckey\u003ecom.apple.security.app-sandbox\u003c/key\u003e\u003ctrue/\u003e\n              \u003ckey\u003ecom.apple.security.network.server\u003c/key\u003e\u003ctrue/\u003e\n              \u003ckey\u003ecom.apple.security.network.client\u003c/key\u003e\u003ctrue/\u003e\n              \u003ckey\u003ecom.apple.security.files.user-selected.read-write\u003c/key\u003e\u003ctrue/\u003e\n              \u003ckey\u003ecom.apple.security.files.downloads.read-write\u003c/key\u003e\u003ctrue/\u003e\n          \u003c/dict\u003e\n          \u003c/plist\u003e\n          ENTITLEMENTS_EOF\n          done\n          cd ../..\n          flutter build macos --release\n      - name: Package\n        run: |\n          cd app_desktop/build/macos/Build/Products/Release\n          zip -r PhotoSync-macOS.zip *.app\n      - uses: actions/upload-artifact@v4\n        with:\n          name: PhotoSync-macOS\n          path: app_desktop/build/macos/Build/Products/Release/PhotoSync-macOS.zip\n          retention-days: 30\n\n  build-linux:\n    name: Linux Desktop\n    runs-on: ubuntu-latest\n    timeout-minutes: 30\n    steps:\n      - uses: actions/checkout@v4\n      - name: Install Linux deps\n        run: |\n          sudo apt-get update -y\n          sudo apt-get install -y clang cmake git ninja-build pkg-config libgtk-3-dev liblzma-dev libstdc++-12-dev\n      - uses: subosito/flutter-action@v2\n        with:\n          flutter-version: '3.24.0'\n          channel: 'stable'\n          cache: true\n      - name: Build\n        run: |\n          flutter config --enable-linux-desktop\n          cd packages/photo_sync_core \u0026\u0026 dart pub get\n          cd ../../app_desktop \u0026\u0026 flutter pub get\n          if [ ! -d \"linux\" ]; then flutter create --platforms=linux . ; fi\n          flutter build linux --release\n      - name: Package\n        run: |\n          cd app_desktop/build/linux/x64/release/bundle\n          tar czf PhotoSync-Linux.tar.gz *\n      - uses: actions/upload-artifact@v4\n        with:\n          name: PhotoSync-Linux\n          path: app_desktop/build/linux/x64/release/bundle/PhotoSync-Linux.tar.gz\n          retention-days: 30\n'''\n\n# Android-only build-apk.yml (同样的 Patch 逻辑)\nbuild_apk = r'''name: Build Android APK\n\non:\n  push:\n    branches: [ main, master ]\n  pull_request:\n    branches: [ main, master ]\n  workflow_dispatch:\n\njobs:\n  build-apk:\n    name: Build APK\n    runs-on: ubuntu-latest\n    timeout-minutes: 30\n    steps:\n      - uses: actions/checkout@v4\n      - uses: actions/setup-java@v4\n        with:\n          distribution: 'zulu'\n          java-version: '17'\n      - uses: subosito/flutter-action@v2\n        with:\n          flutter-version: '3.24.0'\n          channel: 'stable'\n          cache: true\n      - name: Install dependencies\n        run: |\n          cd packages/photo_sync_core \u0026\u0026 dart pub get\n          cd ../../app_mobile \u0026\u0026 flutter pub get\n      - name: Create Android platform files\n        run: |\n          cd app_mobile\n          if [ ! -d \"android\" ]; then flutter create --platforms=android . ; fi\n      - name: Patch Android config\n        run: |\n          cd app_mobile/android\n\n          cat \u003e settings.gradle \u003c\u003c 'SETTINGS_EOF'\n          pluginManagement {\n              def flutterSdkPath = {\n                  def properties = new Properties()\n                  file(\"local.properties\").withInputStream { properties.load(it) }\n                  def flutterSdkPath = properties.getProperty(\"flutter.sdk\")\n                  assert flutterSdkPath != null, \"flutter.sdk not set in local.properties\"\n                  return flutterSdkPath\n              }()\n              includeBuild(\"${flutterSdkPath}/packages/flutter_tools/gradle\")\n              repositories {\n                  google()\n                  mavenCentral()\n                  gradlePluginPortal()\n              }\n          }\n          plugins {\n              id \"dev.flutter.flutter-plugin-loader\" version \"1.0.0\"\n              id \"com.android.application\" version \"8.5.0\" apply false\n              id \"org.jetbrains.kotlin.android\" version \"2.0.0\" apply false\n          }\n          include \":app\"\n          SETTINGS_EOF\n\n          sed -i \"s|distributionUrl=.*|distributionUrl=https\\\\://services.gradle.org/distributions/gradle-8.7-all.zip|\" gradle/wrapper/gradle-wrapper.properties\n\n          cat \u003e app/build.gradle \u003c\u003c 'GRADLE_EOF'\n          plugins {\n              id \"com.android.application\"\n              id \"kotlin-android\"\n              id \"dev.flutter.flutter-gradle-plugin\"\n          }\n\n          android {\n              namespace = \"com.photosync.app\"\n              compileSdk = 34\n              ndkVersion = flutter.ndkVersion\n\n              compileOptions {\n                  sourceCompatibility = JavaVersion.VERSION_1_8\n                  targetCompatibility = JavaVersion.VERSION_1_8\n              }\n\n              kotlinOptions {\n                  jvmTarget = JavaVersion.VERSION_1_8\n              }\n\n              defaultConfig {\n                  applicationId = \"com.photosync.app\"\n                  minSdk = 21\n                  targetSdk = 34\n                  versionCode = flutter.versionCode\n                  versionName = flutter.versionName\n              }\n\n              buildTypes {\n                  release {\n                      signingConfig = signingConfigs.debug\n                  }\n              }\n          }\n\n          flutter {\n              source = \"../..\"\n          }\n          GRADLE_EOF\n\n          cat \u003e app/src/main/AndroidManifest.xml \u003c\u003c 'MANIFEST_EOF'\n          \u003cmanifest xmlns:android=\"http://schemas.android.com/apk/res/android\"\u003e\n              \u003cuses-permission android:name=\"android.permission.INTERNET\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.ACCESS_WIFI_STATE\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.ACCESS_NETWORK_STATE\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.CHANGE_WIFI_MULTICAST_STATE\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.READ_EXTERNAL_STORAGE\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.READ_MEDIA_IMAGES\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.READ_MEDIA_VIDEO\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.CAMERA\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.POST_NOTIFICATIONS\"/\u003e\n              \u003capplication android:label=\"PhotoSync\" android:name=\"${applicationName}\" android:icon=\"@mipmap/ic_launcher\" android:requestLegacyExternalStorage=\"true\"\u003e\n                  \u003cactivity android:name=\".MainActivity\" android:exported=\"true\" android:launchMode=\"singleTop\" android:taskAffinity=\"\" android:theme=\"@style/LaunchTheme\" android:configChanges=\"orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode\" android:hardwareAccelerated=\"true\" android:windowSoftInputMode=\"adjustResize\"\u003e\n                      \u003cmeta-data android:name=\"io.flutter.embedding.android.NormalTheme\" android:resource=\"@style/NormalTheme\"/\u003e\n                      \u003cintent-filter\u003e\u003caction android:name=\"android.intent.action.MAIN\"/\u003e\u003ccategory android:name=\"android.intent.category.LAUNCHER\"/\u003e\u003c/intent-filter\u003e\n                  \u003c/activity\u003e\n                  \u003cmeta-data android:name=\"flutterEmbedding\" android:value=\"2\"/\u003e\n              \u003c/application\u003e\n              \u003cqueries\u003e\u003cintent\u003e\u003caction android:name=\"android.intent.action.PROCESS_TEXT\"/\u003e\u003cdata android:mimeType=\"text/plain\"/\u003e\u003c/intent\u003e\u003c/queries\u003e\n          \u003c/manifest\u003e\n          MANIFEST_EOF\n\n      - name: Build Debug APK\n        run: cd app_mobile \u0026\u0026 flutter build apk --debug\n      - name: Build Release APK\n        run: cd app_mobile \u0026\u0026 flutter build apk --release\n      - uses: actions/upload-artifact@v4\n        with:\n          name: app-debug\n          path: app_mobile/build/app/outputs/flutter-apk/app-debug.apk\n          retention-days: 30\n      - uses: actions/upload-artifact@v4\n        with:\n          name: app-release\n          path: app_mobile/build/app/outputs/flutter-apk/app-release.apk\n          retention-days: 30\n'''\n\n# release.yml\nrelease = r'''name: Release APK\n\non:\n  push:\n    tags:\n      - 'v*'\n\njobs:\n  build-and-release:\n    name: Build \u0026 Release APK\n    runs-on: ubuntu-latest\n    timeout-minutes: 30\n    permissions:\n      contents: write\n    steps:\n      - uses: actions/checkout@v4\n      - uses: actions/setup-java@v4\n        with:\n          distribution: 'zulu'\n          java-version: '17'\n      - uses: subosito/flutter-action@v2\n        with:\n          flutter-version: '3.24.0'\n          channel: 'stable'\n          cache: true\n      - name: Install dependencies\n        run: |\n          cd packages/photo_sync_core \u0026\u0026 dart pub get\n          cd ../../app_mobile \u0026\u0026 flutter pub get\n      - name: Create Android platform files\n        run: |\n          cd app_mobile\n          if [ ! -d \"android\" ]; then flutter create --platforms=android . ; fi\n      - name: Patch Android config\n        run: |\n          cd app_mobile/android\n\n          cat \u003e settings.gradle \u003c\u003c 'SETTINGS_EOF'\n          pluginManagement {\n              def flutterSdkPath = {\n                  def properties = new Properties()\n                  file(\"local.properties\").withInputStream { properties.load(it) }\n                  def flutterSdkPath = properties.getProperty(\"flutter.sdk\")\n                  assert flutterSdkPath != null, \"flutter.sdk not set in local.properties\"\n                  return flutterSdkPath\n              }()\n              includeBuild(\"${flutterSdkPath}/packages/flutter_tools/gradle\")\n              repositories {\n                  google()\n                  mavenCentral()\n                  gradlePluginPortal()\n              }\n          }\n          plugins {\n              id \"dev.flutter.flutter-plugin-loader\" version \"1.0.0\"\n              id \"com.android.application\" version \"8.5.0\" apply false\n              id \"org.jetbrains.kotlin.android\" version \"2.0.0\" apply false\n          }\n          include \":app\"\n          SETTINGS_EOF\n\n          sed -i \"s|distributionUrl=.*|distributionUrl=https\\\\://services.gradle.org/distributions/gradle-8.7-all.zip|\" gradle/wrapper/gradle-wrapper.properties\n\n          cat \u003e app/build.gradle \u003c\u003c 'GRADLE_EOF'\n          plugins {\n              id \"com.android.application\"\n              id \"kotlin-android\"\n              id \"dev.flutter.flutter-gradle-plugin\"\n          }\n\n          android {\n              namespace = \"com.photosync.app\"\n              compileSdk = 34\n              ndkVersion = flutter.ndkVersion\n\n              compileOptions {\n                  sourceCompatibility = JavaVersion.VERSION_1_8\n                  targetCompatibility = JavaVersion.VERSION_1_8\n              }\n\n              kotlinOptions {\n                  jvmTarget = JavaVersion.VERSION_1_8\n              }\n\n              defaultConfig {\n                  applicationId = \"com.photosync.app\"\n                  minSdk = 21\n                  targetSdk = 34\n                  versionCode = flutter.versionCode\n                  versionName = flutter.versionName\n              }\n\n              buildTypes {\n                  release {\n                      signingConfig = signingConfigs.debug\n                  }\n              }\n          }\n\n          flutter {\n              source = \"../..\"\n          }\n          GRADLE_EOF\n\n          cat \u003e app/src/main/AndroidManifest.xml \u003c\u003c 'MANIFEST_EOF'\n          \u003cmanifest xmlns:android=\"http://schemas.android.com/apk/res/android\"\u003e\n              \u003cuses-permission android:name=\"android.permission.INTERNET\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.ACCESS_WIFI_STATE\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.ACCESS_NETWORK_STATE\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.CHANGE_WIFI_MULTICAST_STATE\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.READ_EXTERNAL_STORAGE\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.READ_MEDIA_IMAGES\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.READ_MEDIA_VIDEO\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.CAMERA\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.POST_NOTIFICATIONS\"/\u003e\n              \u003capplication android:label=\"PhotoSync\" android:name=\"${applicationName}\" android:icon=\"@mipmap/ic_launcher\" android:requestLegacyExternalStorage=\"true\"\u003e\n                  \u003cactivity android:name=\".MainActivity\" android:exported=\"true\" android:launchMode=\"singleTop\" android:taskAffinity=\"\" android:theme=\"@style/LaunchTheme\" android:configChanges=\"orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode\" android:hardwareAccelerated=\"true\" android:windowSoftInputMode=\"adjustResize\"\u003e\n                      \u003cmeta-data android:name=\"io.flutter.embedding.android.NormalTheme\" android:resource=\"@style/NormalTheme\"/\u003e\n                      \u003cintent-filter\u003e\u003caction android:name=\"android.intent.action.MAIN\"/\u003e\u003ccategory android:name=\"android.intent.category.LAUNCHER\"/\u003e\u003c/intent-filter\u003e\n                  \u003c/activity\u003e\n                  \u003cmeta-data android:name=\"flutterEmbedding\" android:value=\"2\"/\u003e\n              \u003c/application\u003e\n              \u003cqueries\u003e\u003cintent\u003e\u003caction android:name=\"android.intent.action.PROCESS_TEXT\"/\u003e\u003cdata android:mimeType=\"text/plain\"/\u003e\u003c/intent\u003e\u003c/queries\u003e\n          \u003c/manifest\u003e\n          MANIFEST_EOF\n\n      - name: Build Release APK\n        run: cd app_mobile \u0026\u0026 flutter build apk --release\n      - name: Rename APK with version\n        run: |\n          VERSION=${GITHUB_REF#refs/tags/}\n          cp app_mobile/build/app/outputs/flutter-apk/app-release.apk \\\n             app_mobile/build/app/outputs/flutter-apk/PhotoSync-${VERSION}.apk\n      - name: Create GitHub Release\n        uses: softprops/action-gh-release@v2\n        with:\n          files: |\n            app_mobile/build/app/outputs/flutter-apk/PhotoSync-*.apk\n            app_mobile/build/app/outputs/flutter-apk/app-release.apk\n          generate_release_notes: true\n          draft: false\n          prerelease: false\n'''\n\nbase = '/Users/bytedance/go/src/github.com/liulanghai/photo-sync/.github/workflows'\nfor fname, content in [('build-all.yml', build_all), ('build-apk.yml', build_apk), ('release.yml', release)]:\n    with open(os.path.join(base, fname), 'w') as f:\n        f.write(content)\n    print(f'Written {fname}')\nPYEOF"},"name":"bash"},"id":115}
