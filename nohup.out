DIA_IMAGES\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.READ_MEDIA_VIDEO\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.CAMERA\"/\u003e\n              \u003cuses-permission android:name=\"android.permission.POST_NOTIFICATIONS\"/\u003e\n              \u003capplication android:label=\"PhotoSync\" android:name=\"${applicationName}\" android:icon=\"@mipmap/ic_launcher\" android:requestLegacyExternalStorage=\"true\"\u003e\n                  \u003cactivity android:name=\".MainActivity\" android:exported=\"true\" android:launchMode=\"singleTop\" android:taskAffinity=\"\" android:theme=\"@style/LaunchTheme\" android:configChanges=\"orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode\" android:hardwareAccelerated=\"true\" android:windowSoftInputMode=\"adjustResize\"\u003e\n                      \u003cmeta-data android:name=\"io.flutter.embedding.android.NormalTheme\" android:resource=\"@style/NormalTheme\"/\u003e\n                      \u003cintent-filter\u003e\u003caction android:name=\"android.intent.action.MAIN\"/\u003e\u003ccategory android:name=\"android.intent.category.LAUNCHER\"/\u003e\u003c/intent-filter\u003e\n                  \u003c/activity\u003e\n                  \u003cmeta-data android:name=\"flutterEmbedding\" android:value=\"2\"/\u003e\n              \u003c/application\u003e\n              \u003cqueries\u003e\u003cintent\u003e\u003caction android:name=\"android.intent.action.PROCESS_TEXT\"/\u003e\u003cdata android:mimeType=\"text/plain\"/\u003e\u003c/intent\u003e\u003c/queries\u003e\n          \u003c/manifest\u003e\n          MANIFEST_EOF\n      - name: Configure Kotlin and Gradle\n        run: |\n          cd app_mobile/android\n          # 升级 Kotlin 版本到 1.9.22 以兼容 shared_preferences_android 2.4.7\n          sed -i 's/org.jetbrains.kotlin.android\" version \"[^\"]*\"/org.jetbrains.kotlin.android\" version \"1.9.22\"/' settings.gradle\n          # 兼容旧格式 build.gradle 中的 ext.kotlin_version\n          sed -i 's/ext.kotlin_version = .*/ext.kotlin_version = \"1.9.22\"/' build.gradle || true\n          cd app\n          sed -i 's/minSdk = .*/minSdk = 21/' build.gradle\n          sed -i 's/targetSdk = .*/targetSdk = 34/' build.gradle\n          sed -i 's/compileSdk = .*/compileSdk = 34/' build.gradle\n          sed -i 's/applicationId = .*/applicationId = \"com.photosync.app\"/' build.gradle || true\n          # 打印确认\n          echo \"=== settings.gradle kotlin version ===\"\n          grep -i kotlin ../settings.gradle || true\n          echo \"=== app/build.gradle sdk versions ===\"\n          grep -E '(minSdk|targetSdk|compileSdk)' build.gradle || true\n      - name: Build Release APK\n        run: cd app_mobile \u0026\u0026 flutter build apk --release\n      - uses: actions/upload-artifact@v4\n        with:\n          name: PhotoSync-Android\n          path: app_mobile/build/app/outputs/flutter-apk/app-release.apk\n          retention-days: 30\n\n  build-windows:\n    name: Windows Desktop\n    runs-on: windows-latest\n    timeout-minutes: 30\n    steps:\n      - uses: actions/checkout@v4\n      - uses: subosito/flutter-action@v2\n        with:\n          flutter-version: '3.24.0'\n          channel: 'stable'\n          cache: true\n      - name: Build\n        run: |\n          flutter config --enable-windows-desktop\n          cd packages/photo_sync_core; dart pub get\n          cd ../../app_desktop; flutter pub get\n          if (!(Test-Path \"windows\")) { flutter create --platforms=windows . }\n          flutter build windows --release\n        shell: pwsh\n      - name: Package\n        run: |\n          cd app_desktop/build/windows/x64/runner/Release\n          Compress-Archive -Path * -DestinationPath PhotoSync-Windows.zip\n        shell: pwsh\n      - uses: actions/upload-artifact@v4\n        with:\n          name: PhotoSync-Windows\n          path: app_desktop/build/windows/x64/runner/Release/PhotoSync-Windows.zip\n          retention-days: 30\n\n  build-macos:\n    name: macOS Desktop\n    runs-on: macos-latest\n    timeout-minutes: 30\n    steps:\n      - uses: actions/checkout@v4\n      - uses: subosito/flutter-action@v2\n        with:\n          flutter-version: '3.24.0'\n          channel: 'stable'\n          cache: true\n      - name: Build\n        run: |\n          flutter config --enable-macos-desktop\n          cd packages/photo_sync_core \u0026\u0026 dart pub get\n          cd ../../app_desktop \u0026\u0026 flutter pub get\n          if [ ! -d \"macos\" ]; then flutter create --platforms=macos . ; fi\n          cd macos/Runner\n          for f in DebugProfile.entitlements Release.entitlements; do\n            cat \u003e $f \u003c\u003c 'ENTITLEMENTS_EOF'\n          \u003c?xml version=\"1.0\" encoding=\"UTF-8\"?\u003e\n          \u003c!DOCTYPE plist PUBLIC \"-//Apple//DTD PLIST 1.0//EN\" \"http://www.apple.com/DTDs/PropertyList-1.0.dtd\"\u003e\n          \u003cplist version=\"1.0\"\u003e\n          \u003cdict\u003e\n              \u003ckey\u003ecom.apple.security.app-sandbox\u003c/key\u003e\u003ctrue/\u003e\n              \u003ckey\u003ecom.apple.security.network.server\u003c/key\u003e\u003ctrue/\u003e\n              \u003ckey\u003ecom.apple.security.network.client\u003c/key\u003e\u003ctrue/\u003e\n              \u003ckey\u003ecom.apple.security.files.user-selected.read-write\u003c/key\u003e\u003ctrue/\u003e\n              \u003ckey\u003ecom.apple.security.files.downloads.read-write\u003c/key\u003e\u003ctrue/\u003e\n          \u003c/dict\u003e\n          \u003c/plist\u003e\n          ENTITLEMENTS_EOF\n          done\n          cd ../..\n          flutter build macos --release\n      - name: Package\n        run: |\n          cd app_desktop/build/macos/Build/Products/Release\n          zip -r PhotoSync-macOS.zip *.app\n      - uses: actions/upload-artifact@v4\n        with:\n          name: PhotoSync-macOS\n          path: app_desktop/build/macos/Build/Products/Release/PhotoSync-macOS.zip\n          retention-days: 30\n\n  build-linux:\n    name: Linux Desktop\n    runs-on: ubuntu-latest\n    timeout-minutes: 30\n    steps:\n      - uses: actions/checkout@v4\n      - name: Install Linux deps\n        run: |\n          sudo apt-get update -y\n          sudo apt-get install -y clang cmake git ninja-build pkg-config libgtk-3-dev liblzma-dev libstdc++-12-dev\n      - uses: subosito/flutter-action@v2\n        with:\n          flutter-version: '3.24.0'\n          channel: 'stable'\n          cache: true\n      - name: Build\n        run: |\n          flutter config --enable-linux-desktop\n          cd packages/photo_sync_core \u0026\u0026 dart pub get\n          cd ../../app_desktop \u0026\u0026 flutter pub get\n          if [ ! -d \"linux\" ]; then flutter create --platforms=linux . ; fi\n          flutter build linux --release\n      - name: Package\n        run: |\n          cd app_desktop/build/linux/x64/release/bundle\n          tar czf PhotoSync-Linux.tar.gz *\n      - uses: actions/upload-artifact@v4\n        with:\n          name: PhotoSync-Linux\n          path: app_desktop/build/linux/x64/release/bundle/PhotoSync-Linux.tar.gz\n          retention-days: 30\n'''\nwith open('/Users/bytedance/go/src/github.com/liulanghai/photo-sync/.github/workflows/build-all.yml', 'w') as f:\n    f.write(content)\nprint('build-all.yml written')\nPYEOF"},"name":"bash"},"id":73}
